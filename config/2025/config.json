          "type": "select",
          "required": false,
          "choices": {
            "None": "None"
          },
          "defaultValue": "None"
        }
      ]
    },
    {
      "name": "Postmatch",
      "preserveDataOnReset": false,
      "fields": [
        {
          "code": "broke",
          "title": "Robot Broke",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        },
        {
          "code": "Dth",
          "title": "Died/Tipped Over",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        },
        {
          "code": "Fouls",
          "title": "Foul",
          "type": "counter",
          "defaultValue": 0,
          "min": 0,
          "required": false
        },
        {
          "code": "Card",
