        },
        {
          "code": "aBump",
          "title": "Travel over Bump",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        },
        {
          "code": "aTrench",
          "title": "Travel over Trench",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        },
        {
          "code": "aTower",
          "title": "Tower Scoring",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        }
      ]
    },
    {
      "name": "Teleop",
      "preserveDataOnReset": false,
      "fields": [
        {
          "code": "tBalls",
          "title": "Balls Scored",
          "type": "counter",
          "defaultValue": 0,
          "min": 0,
          "required": false,
          "steps": [1, 3, 5]
        },
        {
          "code": "tMiss",
          "title": "Missed Shots",
          "type": "counter",
          "defaultValue": 0,
          "min": 0,
          "required": false,
          "steps": [1, 3, 5]
        },
        {
          "code": "tBump",
          "title": "Travel over Bump",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        },
        {
          "code": "tTrench",
          "title": "Travel over Trench",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        },
        {
          "code": "tTower",
          "title": "Tower Scoring",
          "type": "select",
          "required": false,
          "choices": {
            "None": "None",
            "L1": "L1",
            "L2": "L2",
            "L3": "L3"
          },
          "defaultValue": "None"
        }
