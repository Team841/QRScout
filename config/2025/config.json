          "type": "select",
          "choices": {
            "None": "None",
            "Red": "Red",
            "Green": "Green"
          },
          "required": false
        },
        {
          "code": "co",
          "title": "Comments",
          "type": "text",
          "min": 0,
          "max": 300,
          "required": true
        }
      ]
    }
