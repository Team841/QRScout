          "defaultValue": 0,
          "min": 0,
          "required": false,
          "steps": [1, 3, 5]
        },
        {
          "code": "aMiss",
          "title": "Missed Shots",
          "type": "counter",
          "defaultValue": 0,
          "min": 0,
          "required": false,
